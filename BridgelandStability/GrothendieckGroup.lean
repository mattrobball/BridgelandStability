import Mathlib.CategoryTheory.Triangulated.Pretriangulated
import Mathlib.GroupTheory.FreeAbelianGroup
import Mathlib.GroupTheory.QuotientGroup.Defs

/-!
# Grothendieck Group of a Triangulated Category

We define the Grothendieck group `K‚āÄ C` of a pretriangulated category `C` as the free abelian
group on objects of `C` modulo the distinguished triangle relations:
`[B] = [A] + [C]` for each distinguished triangle `A ‚Üí B ‚Üí C ‚Üí A‚ü¶1‚üß`.

The isomorphism relation `[X] = [Y]` for `X ‚ČÖ Y` is derivable from the triangle relations
(via the distinguished triangle `X ‚Üí Y ‚Üí 0 ‚Üí X‚ü¶1‚üß`), so we do not include it as a separate
generator.

## Main definitions

* `CategoryTheory.Triangulated.K‚āÄSubgroup`: the subgroup of triangle relations
* `CategoryTheory.Triangulated.K‚āÄ`: the Grothendieck group with its `AddCommGroup` instance
* `CategoryTheory.Triangulated.K‚āÄ.of`: the class map `C ‚Üí K‚āÄ C`
* `CategoryTheory.Triangulated.K‚āÄ.of_triangle`: additivity on distinguished triangles
-/

noncomputable section

open CategoryTheory CategoryTheory.Limits

universe v u

namespace CategoryTheory.Triangulated

variable (C : Type u) [Category.{v} C] [HasZeroObject C] [HasShift C ‚Ą§]
  [Preadditive C] [‚ąÄ n : ‚Ą§, (shiftFunctor C n).Additive] [Pretriangulated C]

/-- The subgroup of `FreeAbelianGroup C` generated by the distinguished triangle relations:
`[T.obj‚āā] - [T.obj‚āĀ] - [T.obj‚āÉ]` for each distinguished triangle `T`.

The isomorphism relations `[X] - [Y]` for `X ‚ČÖ Y` are derivable, since any isomorphism
gives rise to a distinguished triangle with a zero third vertex. -/
def K‚āÄSubgroup : AddSubgroup (FreeAbelianGroup C) :=
  AddSubgroup.closure
    {x | ‚ąÉ (T : Pretriangulated.Triangle C), (T ‚ąą distTriang C) ‚ąß
        x = FreeAbelianGroup.of T.obj‚āā - FreeAbelianGroup.of T.obj‚āĀ -
          FreeAbelianGroup.of T.obj‚āÉ}

/-- The Grothendieck group of a pretriangulated category `C`, defined as the quotient of
`FreeAbelianGroup C` by the distinguished triangle relations. -/
def K‚āÄ : Type _ := FreeAbelianGroup C ‚ßł K‚āÄSubgroup C

/-- The `AddCommGroup` instance on `K‚āÄ C`, inherited from the quotient. -/
instance K‚āÄ.instAddCommGroup : AddCommGroup (K‚āÄ C) :=
  inferInstanceAs (AddCommGroup (FreeAbelianGroup C ‚ßł K‚āÄSubgroup C))

/-- The class map sending an object `X` of `C` to its class `[X]` in `K‚āÄ C`. -/
def K‚āÄ.of (X : C) : K‚āÄ C :=
  (QuotientAddGroup.mk (FreeAbelianGroup.of X) : FreeAbelianGroup C ‚ßł K‚āÄSubgroup C)

/-- For a distinguished triangle `T`, the class of `T.obj‚āā` equals the sum of the classes of
`T.obj‚āĀ` and `T.obj‚āÉ` in `K‚āÄ C`. -/
lemma K‚āÄ.of_triangle (T : Pretriangulated.Triangle C) (hT : T ‚ąą distTriang C) :
    K‚āÄ.of C T.obj‚āā = K‚āÄ.of C T.obj‚āĀ + K‚āÄ.of C T.obj‚āÉ := by
  simp only [K‚āÄ.of, K‚āÄ, ‚Üź QuotientAddGroup.mk_add]
  apply Quotient.sound
  change QuotientAddGroup.leftRel _ _ _
  rw [QuotientAddGroup.leftRel_apply]
  have h : FreeAbelianGroup.of T.obj‚āā - FreeAbelianGroup.of T.obj‚āĀ -
    FreeAbelianGroup.of T.obj‚āÉ ‚ąą K‚āÄSubgroup C :=
    AddSubgroup.subset_closure ‚ü®T, hT, rfl‚ü©
  convert (K‚āÄSubgroup C).neg_mem h using 1
  abel

end CategoryTheory.Triangulated
